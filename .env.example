# Copy to .env and fill in real values before deploying.

POSTGRES_DB=unifiedapi
POSTGRES_USER=unifiedapi
POSTGRES_PASSWORD=change-me

# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# Public URL of the deployed frontend (Dokploy domain, e.g. https://app.yourdomain.com)
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# OAuth2 (optional — leave blank if not using LinkedIn/Twitter login)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
